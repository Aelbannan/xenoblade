{
  "project_adapter": "tools.llm_harness.xenoblade_project",
  "output_dir": "build/llm-harness",
  "project": {
    "coop_config": "coop.json",
    "prompt_dir": "tools/llm_harness/prompts",
    "max_source_chars": 120000,
    "context_similar_limit": 3,
    "tu_context_chars": 1500,
    "tu_section_byte_limit": 16384
  },
  "providers": {
    "opencode": {
      "binary": "opencode",
      "timeout_seconds": 900,
      "pure": true
    },
    "reasonix": {
      "binary": "reasonix",
      "timeout_seconds": 900,
      "pure": true
    },
    "deepseek-raw": {
      "binary": "deepseek-raw",
      "timeout_seconds": 300,
      "pure": true
    },
    "openrouter": {
      "timeout_seconds": 300,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "allow_fallbacks": true,
      "pure": true
    },
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "api_key": "lm-studio",
      "timeout_seconds": 900,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "enable_thinking": false,
      "reasoning_effort": "none",
      "thinking_budget": 0
    },
    "codex": {
      "binary": "codex",
      "timeout_seconds": 900,
      "pure": true,
      "sandbox": "read-only",
      "ephemeral": true,
      "json_schema": true
    }
  },
  "models": {
    "initial": [
      {
        "id": "opencode-deepseek-flash",
        "provider": "opencode",
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "high",
        "runs": 1
      },
      {
        "id": "omlx-qwen-3.5-6b",
        "provider": "omlx",
        "model": "mlx-community/ThinkingCap-Qwen3.6-27B-mlx-6Bit",
        "runs": 1,
        "enable_thinking": true,
        "reasoning_effort": "high",
        "thinking_budget": 8192
      },
	  {
		"id": "or-deepseek",
		"provider": "openrouter",
		"model": "deepseek/deepseek-chat",
		"variant": "deepseek",
		"runs": 1
	  }
    ],
    "repair": [
      {
        "id": "deepseek-pro",
        "provider": "deepseek-raw",
        "model": "deepseek-pro",
        "runs": 1
      }
    ],
    "tu": [
      {
        "id": "openrouter-deepseek",
        "provider": "openrouter",
        "model": "deepseek/deepseek-chat",
        "variant": "deepseek",
        "runs": 1
      }
    ],
    "sample": [
      {
        "id": "lmstudio-local",
        "provider": "lmstudio",
        "model": "qwen2.5-coder-32b-instruct",
        "runs": 1
      },
      {
        "id": "codex-gpt",
        "provider": "codex",
        "model": "gpt-5.4",
        "reasoning_effort": "low",
        "runs": 1
      }
    ]
  },
  "execution": {
    "initial_parallel": 3,
    "target_parallel": 2,
    "max_retries": 0,
    "auto_promote": true,
    "auto_promote_owner": "llm-harness",
    "auto_promote_deferred": false,
    "isolation": {
      "mode": "git-worktree",
      "copy_dirty": true
    }
  },
  "solve": {
    "initial_candidates": 2,
    "compile_repairs": 1,
    "match_repairs": 3,
    "max_repeated_fingerprint": 2,
    "stop_on_full_match": true,
    "stop_on_equivalent_match": true
  },
  "prompt": {
    "max_chars": 60000,
    "max_decoded_instructions": 400,
    "max_declaration_chars": 12000,
    "max_callers": 3,
    "max_sibling_bodies": 3,
    "include_raw_hex": false,
    "max_output_tokens": 4096
  }
}
