{
  "project_adapter": "tools.llm_harness.xenoblade_project",
  "output_dir": "build/llm-harness",
  "project": {
    "coop_config": "coop.json",
    "prompt_dir": "tools/llm_harness/prompts",
    "max_source_chars": 120000,
    "context_similar_limit": 3,
    "tu_context_chars": 1500,
    "tu_section_byte_limit": 16384
  },
  "providers": {
    "opencode": {
      "binary": "opencode",
      "timeout_seconds": 360,
      "pure": true
    },
    "deepseek-raw": {
      "binary": "deepseek-raw",
      "timeout_seconds": 300,
      "pure": true
    },
    "openrouter": {
      "timeout_seconds": 300,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "allow_fallbacks": true,
      "pure": true
    },
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "timeout_seconds": 900,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "enable_thinking": true,
      "reasoning_effort": "none",
      "thinking_budget": 0
    },
    "omlx": {
      "base_url": "http://127.0.0.1:8000/v1",
      "timeout_seconds": 900,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "enable_thinking": true,
      "reasoning_effort": "high",
      "thinking_budget": 8192
    },
    "codex": {
      "binary": "codex",
      "timeout_seconds": 900,
      "pure": true,
      "sandbox": "read-only",
      "ephemeral": true,
      "json_schema": false
    }
  },
  "models": {
    "default": [
      {
		"id": "or-mimo-2.5",
		"provider": "openrouter",
		"model": "xiaomi/mimo-v2.5",
		"runs": 1
	  }
    ]
  },
  "execution": {
    "initial_parallel": 2,
    "target_parallel": 4,
    "max_retries": 0,
    "auto_promote": true,
    "auto_promote_owner": "llm-harness",
    "auto_promote_deferred": false,
    "isolation": {
      "mode": "git-worktree",
      "copy_dirty": true
    }
  },
  "solve": {
    "initial_candidates": 2,
    "compile_repairs": 3,
    "match_repairs": 5,
    "max_repeated_fingerprint": 2,
    "stop_on_full_match": true,
    "stop_on_equivalent_match": true
  },
  "solve-local": {
    "initial_candidates": 1,
    "compile_repairs": 2,
    "match_repairs": 3,
    "max_repeated_fingerprint": 1,
    "strategies": ["typed"],
    "stop_on_full_match": true,
    "stop_on_equivalent_match": true,
    "stop_if_all_initial_compile_error": true,
    "reject_noop_compile_repair": true
  },
  "prompt": {
    "max_chars": 60000,
    "max_decoded_instructions": 4096,
    "max_declaration_chars": 12000,
    "max_callers": 3,
    "max_sibling_bodies": 3,
    "include_raw_hex": false,
    "max_output_tokens": 4096
  }
}
