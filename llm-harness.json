{
  "project_adapter": "tools.llm_harness.xenoblade_project",
  "output_dir": "build/llm-harness",
  "project": {
    "coop_config": "coop.json",
    "prompt_dir": "tools/llm_harness/prompts",
    "max_source_chars": 120000,
    "context_similar_limit": 3,
    "tu_context_chars": 1500,
    "tu_section_byte_limit": 16384
  },
  "providers": {
    "opencode": {
      "binary": "opencode",
      "timeout_seconds": 900,
      "pure": true
    },
    "deepseek-raw": {
      "binary": "deepseek-raw",
      "timeout_seconds": 300,
      "pure": true
    },
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "timeout_seconds": 900,
      "temperature": 0.1,
      "max_tokens": 4096,
      "json_object": true,
      "enable_thinking": true,
      "reasoning_effort": "low",
      "thinking_budget": 1024
    }
  },
  "models": {
    "initial": [
      {
        "id": "lmstudio-local",
        "provider": "lmstudio",
        "model": "google/gemma-4-26b-a4b",
        "runs": 1
      }
    ],
    "repair": [
      {
        "id": "lmstudio-local",
        "provider": "lmstudio",
        "model": "google/gemma-4-26b-a4b",
        "runs": 1
      }
    ],
    "tu": [
      {
        "id": "lmstudio-local",
        "provider": "lmstudio",
        "model": "google/gemma-4-26b-a4b",
        "runs": 1
      }
    ],
    "sample": [
      {
        "id": "lmstudio-local",
        "provider": "lmstudio",
        "model": "google/gemma-4-26b-a4b",
        "runs": 1
      }
    ]
  },
  "execution": {
    "initial_parallel": 3,
    "target_parallel": 2,
    "max_retries": 1,
    "auto_promote": true,
    "auto_promote_owner": "llm-harness",
    "isolation": {
      "mode": "git-worktree",
      "copy_dirty": true
    }
  },
  "solve": {
    "initial_candidates": 3,
    "compile_repairs": 2,
    "match_repairs": 4,
    "max_repeated_fingerprint": 2,
    "stop_on_full_match": true,
    "stop_on_equivalent_match": true
  },
  "prompt": {
    "max_chars": 60000,
    "max_decoded_instructions": 400,
    "max_declaration_chars": 12000,
    "max_callers": 3,
    "max_sibling_bodies": 3,
    "include_raw_hex": false,
    "max_output_tokens": 4096
  }
}
