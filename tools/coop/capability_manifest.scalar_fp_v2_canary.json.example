{
  "schema_version": 1,
  "policy": "capability-assurance-v1",
  "description": "Shadow/canary manifest for scalar FP exact v2 rollout (Phase 12). Copy to a local path and set SCALAR_FP_EXACT_V2_ALLOWLIST_MANIFEST. automatic_promotion must stay false until bottom-up recertification passes.",
  "automatic_promotion": false,
  "shadow_mode": true,
  "scalar_fp_exact_v2": {
    "experimental_env": "SCALAR_FP_EXACT_V2",
    "production_env": "SCALAR_FP_EXACT_V2_PRODUCTION",
    "allowlist_order": [
      "fp-load-store",
      "fp-compare",
      "fp-convert",
      "fp-fpscr-control",
      "fp-scalar-arithmetic",
      "fp-traps",
      "fp-fused-arithmetic"
    ],
    "recommended_canary_targets": {
      "fp-load-store": "us-80040998",
      "fp-bitwise": "us-803e9714",
      "fp-convert": "us-802c9b90",
      "fp-fpscr-control": "us-802dd650",
      "fp-scalar-arithmetic": "us-802dd650"
    }
  },
  "allowed_tier_a_capabilities": {
    "integer-core": ["integer-core-v1"],
    "provenance": ["provenance-v1"],
    "bounded-memory": ["bounded-memory-v2"],
    "certified-calls": ["certified-calls-v2"],
    "fp-bitwise": ["fp-bitwise-v1"],
    "fp-load-store": [],
    "fp-compare": [],
    "fp-convert": [],
    "fp-fpscr-control": [],
    "fp-scalar-arithmetic": [],
    "fp-fused-arithmetic": [],
    "fp-paired-single": [],
    "fp-psq": [],
    "fp-traps": [],
    "precondition-closure": [],
    "mmio-register-bank": [],
    "gx-fifo-write-trace": [],
    "gx-fifo-read": [],
    "mmio-read-side-effects": [],
    "mmio-external-input": [],
    "mmio-loop-emission": [],
    "mixed-address-space-routing": [],
    "dma-interrupt-effects": [],
    "memory-loop-summary": [],
    "immutable-address-space": [],
    "indirect-target-closure": [],
    "affine-loop-summary": [],
    "relational-loop-induction": []
  },
  "require_capability_assurance": true
}
